# Application
APP_NAME="Nelson Tour and Safari API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nelson_tour_safari
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/nelson_tour_safari

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3 (alternative to Cloudinary)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_BUCKET_NAME=nelson-tour-safari-media

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Admin
FIRST_ADMIN_EMAIL=admin@nelsontoursandsafari.com
FIRST_ADMIN_PASSWORD=ChangeMe123!

# Email — via Amazon SES
# Prerequisites:
#   1. Have or create an AWS account
#   2. Verify your domain (nelsontoursandsafaris.com) in SES: SES → Identities → Create Domain
#   3. Verify the sender email (noreply@nelsontoursandsafaris.com) or have the domain verified
#   4. If still in SES sandbox, verify each recipient email or request production access
#   5. Create an IAM user with ses:SendEmail permission and get access keys
#
# Required variables:
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@nelsontoursandsafaris.com
#
# Admin notifications will go to EMAIL_FROM below:
EMAIL_FROM=ngoekenedy@gmail.com
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://your-api-domain.com

# Pesapal Payment Gateway (https://developer.pesapal.com)
# Sandbox: https://cybqa.pesapal.com/pesapalv3
# Live:    https://pay.pesapal.com/v3
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
PESAPAL_ENVIRONMENT=sandbox
# Optional: set after first run to skip re-registering IPN on every boot
PESAPAL_IPN_ID=
