# ── Environment: development | production ──────────────────────────────────
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# ── Database ──────────────────────────────────────────────────────────────
# With Docker Compose: DB_PASSWORD is used in docker-compose.yml's
#   DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD:?err}@db:5432/karibu_safari
# Without Docker: set DATABASE_URL directly below
DB_PASSWORD=your_strong_db_password_here
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@localhost:5432/karibu_safari
DATABASE_URL_SYNC=postgresql://postgres:${DB_PASSWORD}@localhost:5432/karibu_safari

# ── Redis (optional in dev, required in production) ────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Admin seed (only used if no admin exists yet) ─────────────────────────
FIRST_ADMIN_EMAIL=info@nelsontoursandsafaris.com
# Change immediately after first login
FIRST_ADMIN_PASSWORD=ChangeMe123!

SUPER_ADMIN_EMAIL=info@nelsontoursandsafaris.com
SUPER_ADMIN_PASSWORD=admin@123
SUPER_ADMIN_NAME=Kenedy

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="Nelson Tours & Safari <info@nelsontoursandsafaris.com>"
EMAIL_FROM=info@nelsontoursandsafaris.com
BCC_EMAILS=nelsonmichael90@gmail.com
FRONTEND_URL=https://nelsontoursandsafaris.com
BACKEND_URL=https://api.nelsontoursandsafaris.com

# ── Payments (Pesapal) ────────────────────────────────────────────────────
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_IPN_ID=

# ── Media (Cloudinary) ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Media (AWS S3 — alternative to Cloudinary) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ── Performance ───────────────────────────────────────────────────────────
WEB_CONCURRENCY=8
